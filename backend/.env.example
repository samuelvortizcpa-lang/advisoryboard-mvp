# ==========================================================================
# Copy this file to .env.local (NOT .env) and fill in your values.
# ==========================================================================
# The backend loads .env.local via Pydantic Settings and python-dotenv.
# A file named .env is ignored — the load path is pinned to .env.local.
#
# WARNING: .env.local is for LOCAL DEV ONLY.
# DATABASE_URL here must point to your local Postgres, never production.
# Production config is injected by Railway — it is never edited via this file.
# ==========================================================================

# Application
APP_ENV=development
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/advisoryboard

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Frontend
FRONTEND_URL=http://localhost:3000

# Clerk (https://dashboard.clerk.com -> API Keys)
# Frontend API URL: Settings -> API Keys -> "Clerk Frontend API" (no trailing slash)
# Example: https://your-app.clerk.accounts.dev
CLERK_FRONTEND_API_URL=your-clerk-frontend-api-url-here
# Secret key: Settings -> API Keys -> "Secret keys" (sk_test_... or sk_live_...)
CLERK_SECRET_KEY=your-clerk-secret-key-here
