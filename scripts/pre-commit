#!/bin/sh
# Pre-commit hook: TypeScript typecheck
# Prevents committing code that doesn't compile.
# Install: make hooks (or cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit)

echo "Pre-commit: running tsc --noEmit..."

cd frontend && npx tsc --noEmit 2>&1
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
    echo ""
    echo "TypeScript compilation failed. Fix the errors above before committing."
    exit 1
fi

echo "Pre-commit: TypeScript check passed."
exit 0
