{
  "manifest_version": 3,
  "name": "Callwen — Document Capture for CPAs",
  "version": "1.0.2",
  "description": "Capture documents, emails, and financial data from any webpage directly into your Callwen client files. Built for CPAs.",
  "author": "AdvisoryBoard, Inc.",
  "homepage_url": "https://callwen.com",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "contextMenus",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://advisoryboard-mvp-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "commands": {
    "_execute_side_panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Open Quick Query side panel"
    }
  }
}
