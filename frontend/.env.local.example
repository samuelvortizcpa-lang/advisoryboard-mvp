# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Backend API ──────────────────────────────────────────────────────────────
# Public: used by client-side API calls (baked in at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-only: used by the admin API proxy (never exposed to the browser)
BACKEND_URL=http://localhost:8000

# ─── Admin Access ────────────────────────────────────────────────────────────
# Comma-separated Clerk user IDs that are allowed to access /admin/* routes.
# The admin API proxy also forwards the user's Clerk JWT to the backend,
# which independently checks against its own ADMIN_USER_ID setting.
ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxxxxxx

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# SENTRY_AUTH_TOKEN=sntrys_...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
